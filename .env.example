# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/newspaper_ai

# Admin API
ADMIN_API_TOKEN=replace-with-a-long-random-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Fetcher schedule (minutes between fetch runs)
FETCH_INTERVAL_MINUTES=10
FETCH_NEWS_TIMEZONE=Asia/Kolkata

# App
APP_ENV=development
LOG_LEVEL=INFO
